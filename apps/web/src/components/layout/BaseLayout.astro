---
import Navbar from "./Navbar.astro";
import Footer from "./Footer.astro";
import CartDrawer from "@/components/islands/CartDrawer";
import { getCurrentUser } from "@/lib/auth";
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
  user?: { name: string } | null;
}

const {
  title = "My Ecommerce",
  description = "Belanja produk terbaik dengan harga terjangkau",
} = Astro.props;

// Get user from cookie (SSR)
const user = await getCurrentUser(Astro.cookies);
---

<!doctype html>
<html lang="id" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — My Ecommerce</title>
    <!-- Inter font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen bg-white text-gray-900 antialiased">
    <!-- Cart drawer (React island, always mounted client-side) -->
    <CartDrawer client:load />

    <Navbar user={user} />

    <main>
      <slot />
    </main>

    <Footer />

    <!-- Hydrate cart from localStorage on mount -->
    <script>
      import { hydrateCart } from "@/stores/cart.store";
      hydrateCart();
    </script>
  </body>
</html>

