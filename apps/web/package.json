{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "description": "Customer-facing storefront — Astro SSR + React islands + Tailwind CSS",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "typecheck": "astro check && tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "clean": "rm -rf .turbo dist node_modules"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.4",
    "@nanostores/react": "^0.7.3",
    "@repo/env": "workspace:*",
    "@repo/ui": "workspace:*",
    "astro": "^6.1.10",
    "nanostores": "^1.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.0"
 }
}
