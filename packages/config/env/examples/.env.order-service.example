# =============================================================================
# apps/order-service — Environment Variables
# Copy: cp packages/config/env/examples/.env.order-service.example apps/order-service/.env
# =============================================================================

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3003

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=orders

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-secure-random-string-minimum-32-chars

# ── Internal Service URLs ─────────────────────────────────────────────────────
PRODUCT_SERVICE_URL=http://localhost:3002
PAYMENT_SERVICE_URL=http://localhost:3004

# ── Redis (BullMQ job queues) ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Order settings ────────────────────────────────────────────────────────────
ORDER_EXPIRY_MINUTES=60

# ── RajaOngkir (shipping cost calculation) ────────────────────────────────────
RAJAONGKIR_API_KEY=your-api-key-from-rajaongkir.com
# Jakarta Pusat city ID = 501 — change to your warehouse city
RAJAONGKIR_ORIGIN=501

# ── Internal service URLs ─────────────────────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:3001
