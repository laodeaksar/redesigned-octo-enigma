{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  },
  "globalDotenv": [".env"],
  "pipeline": {
    "build": {
      "inputs": ["$MIDTRANS_SERVER_KEY", "$DATABASE_URL"],
      "dependsOn": ["^build"]
    },
    "lint": {
      "outputs": []
    }
  }
}
