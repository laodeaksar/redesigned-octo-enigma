{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "React Library / TanStack Start",
  "extends": "./base.json",
  "compilerOptions": {
    "lib":              ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "Bundler",
    "module":           "ESNext",
    "jsx":              "react-jsx",

    /* Allow .tsx imports without extension */
    "allowImportingTsExtensions": true,

    /* Emit declarations for packages/ui consumers */
    "noEmit":           false,
    "emitDeclarationOnly": true,
    "outDir":           "./dist"
  },
  "include": ["src", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
