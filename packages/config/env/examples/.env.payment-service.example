# =============================================================================
# apps/payment-service — Environment Variables
# Copy: cp packages/config/env/examples/.env.payment-service.example apps/payment-service/.env
# =============================================================================

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3004

# ── JWT ───────────────────────────────────────────────────────────────────────
# Used to verify tokens forwarded from api-gateway via x-user-* headers
JWT_SECRET=change-me-to-a-secure-random-string-minimum-32-chars

# ── Midtrans ──────────────────────────────────────────────────────────────────
# Dashboard: https://dashboard.sandbox.midtrans.com > Settings > Access Keys
# Use sandbox keys for development, production keys for production
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxx
# Set to "true" only in production — sandbox keys won't work in production mode
MIDTRANS_IS_PRODUCTION=false

# Midtrans will POST payment status notifications to this URL.
# In development, use a tunnel tool:
#   ngrok:    ngrok http 3000  →  https://<id>.ngrok.io/payments/webhook
#   cloudflared: cloudflared tunnel --url http://localhost:3000
PAYMENT_WEBHOOK_URL=https://your-ngrok-url.ngrok.io/payments/webhook

# ── Internal Service URLs ─────────────────────────────────────────────────────
ORDER_SERVICE_URL=http://localhost:3003

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672