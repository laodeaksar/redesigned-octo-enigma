---
// =============================================================================
// OAuth callback page
// After Better-auth completes the OAuth flow, it redirects to this page.
// We exchange the Better-auth session for our JWT tokens and set cookies.
// =============================================================================

import BaseLayout from "@/components/layout/BaseLayout.astro";
import { setAuthCookies } from "@/lib/auth";
import { api } from "@/lib/api";

// Better-auth appends a session token as a query param or sets a cookie.
// We call /auth/me with the Better-auth session to get our JWT tokens.
const betterAuthToken = Astro.url.searchParams.get("token") ?? "";
const errorParam      = Astro.url.searchParams.get("error");

let redirectTo = "/";
let errorMessage: string | null = null;

if (errorParam) {
  errorMessage = decodeURIComponent(errorParam);
} else if (betterAuthToken) {
  try {
    // Exchange Better-auth token for our JWT pair
    const res = await api.post<{
      success: true;
      data: { accessToken: string; refreshToken: string; expiresIn: number };
    }>("/auth/oauth/exchange", { token: betterAuthToken });

    setAuthCookies(
      Astro.cookies,
      res.data.accessToken,
      res.data.refreshToken,
      res.data.expiresIn
    );

    // Redirect to originally intended destination
    return Astro.redirect(redirectTo, 302);
  } catch (err) {
    errorMessage = "Login OAuth gagal. Silakan coba lagi.";
  }
} else {
  // No token — redirect to login
  return Astro.redirect("/auth/login", 302);
}
---

<BaseLayout title="Menghubungkan Akun">
  <div class="flex min-h-[calc(100vh-8rem)] items-center justify-center px-4 py-12">
    <div class="w-full max-w-sm text-center">
      {errorMessage ? (
        <div class="rounded-2xl border border-red-100 bg-red-50 p-8">
          <p class="text-2xl mb-3">❌</p>
          <h1 class="text-lg font-bold text-gray-900 mb-2">Login Gagal</h1>
          <p class="text-sm text-gray-600 mb-6">{errorMessage}</p>
          <a href="/auth/login"
            class="inline-block rounded-lg bg-accent px-6 py-2.5 text-sm font-semibold text-white hover:opacity-90">
            Kembali ke Login
          </a>
        </div>
      ) : (
        <div class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-brand-500/10">
            <svg class="h-6 w-6 animate-spin text-brand-500" viewBox="0 0 24 24" fill="none">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
            </svg>
          </div>
          <p class="text-sm text-gray-600">Menghubungkan akun, harap tunggu…</p>
        </div>
      )}
    </div>
  </div>
</BaseLayout>
