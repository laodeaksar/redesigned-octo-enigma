---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import ProductCard from "@/components/shared/ProductCard.astro";
import Pagination from "@/components/shared/Pagination.astro";
import { api, type Product, type Category } from "@/lib/api";

const { searchParams } = Astro.url;
const page = parseInt(searchParams.get("page") ?? "1", 10);
const search = searchParams.get("q") ?? "";
const categoryId = searchParams.get("categoryId") ?? "";
const sortBy = searchParams.get("sortBy") ?? "createdAt";
const sortOrder = searchParams.get("sortOrder") ?? "desc";

let products: Product[] = [];
let totalPages = 1;
let total = 0;
let categories: Category[] = [];

try {
  const [productsRes, categoriesRes] = await Promise.all([
    api.get<{ success: true; data: Product[]; meta: { total: number; page: number; limit: number; totalPages: number } }>(
      "/products",
      {
        params: {
          page, limit: 24, status: "active",
          search: search || undefined,
          categoryId: categoryId || undefined,
          sortBy, sortOrder,
        },
      }
    ),
    api.get<{ success: true; data: Category[] }>("/categories"),
  ]);

  products = productsRes.data;
  totalPages = productsRes.meta.totalPages;
  total = productsRes.meta.total;
  categories = categoriesRes.data.filter((c) => !c.parentId);
} catch {
  // show empty state
}

const baseUrl = "/products";
const currentCategory = categories.find((c) => c.id === categoryId);
const pageTitle = currentCategory ? currentCategory.name : "Semua Produk";

const sortOptions = [
  { value: "createdAt_desc", label: "Terbaru" },
  { value: "createdAt_asc", label: "Terlama" },
  { value: "lowestPrice_asc", label: "Harga Terendah" },
  { value: "lowestPrice_desc", label: "Harga Tertinggi" },
];
---

<BaseLayout title={pageTitle}>
  <div class="container mx-auto px-4 py-10">
    <div class="flex flex-col gap-8 lg:flex-row">

      <!-- Sidebar filters -->
      <aside class="w-full lg:w-56 shrink-0">
        <div class="sticky top-24 space-y-6">

          <!-- Search -->
          <form method="get" action="/products">
            <label class="mb-1.5 block text-xs font-semibold uppercase tracking-wide text-gray-500">
              Cari
            </label>
            <div class="flex overflow-hidden rounded-lg border border-gray-200">
              <input
                type="search"
                name="q"
                value={search}
                placeholder="Nama produk…"
                class="flex-1 px-3 py-2 text-sm outline-none"
              />
              <button type="submit" class="px-3 text-gray-400 hover:text-gray-700">🔍</button>
            </div>
            {categoryId && <input type="hidden" name="categoryId" value={categoryId} />}
          </form>

          <!-- Categories -->
          <div>
            <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-gray-500">
              Kategori
            </p>
            <ul class="space-y-1">
              <li>
                <a
                  href="/products"
                  class:list={[
                    "block rounded-md px-3 py-1.5 text-sm transition-colors",
                    !categoryId ? "bg-brand-500 font-semibold text-white" : "text-gray-600 hover:bg-gray-100",
                  ]}
                >
                  Semua Produk
                </a>
              </li>
              {categories.map((cat) => (
                <li>
                  <a
                    href={`/products?categoryId=${cat.id}`}
                    class:list={[
                      "block rounded-md px-3 py-1.5 text-sm transition-colors",
                      categoryId === cat.id
                        ? "bg-brand-500 font-semibold text-white"
                        : "text-gray-600 hover:bg-gray-100",
                    ]}
                  >
                    {cat.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </aside>

      <!-- Main content -->
      <div class="flex-1">

        <!-- Header bar -->
        <div class="mb-6 flex flex-wrap items-center justify-between gap-4">
          <div>
            <h1 class="text-xl font-bold text-gray-900">{pageTitle}</h1>
            <p class="mt-0.5 text-sm text-gray-500">{total} produk ditemukan</p>
          </div>

          <form method="get" action="/products" class="flex items-center gap-2">
            {categoryId && <input type="hidden" name="categoryId" value={categoryId} />}
            {search && <input type="hidden" name="q" value={search} />}
            <label class="text-sm text-gray-600">Urutkan:</label>
            <select
              name="sortBy"
              onchange="this.form.submit()"
              class="rounded-lg border border-gray-200 px-3 py-2 text-sm outline-none focus:border-brand-500"
            >
              {sortOptions.map((opt) => {
                const [field, order] = opt.value.split("_");
                const isSelected = sortBy === field && sortOrder === order;
                return (
                  <option value={opt.value} selected={isSelected}>{opt.label}</option>
                );
              })}
            </select>
          </form>
        </div>

        <!-- Products grid -->
        {products.length === 0 ? (
          <div class="flex flex-col items-center gap-3 py-24 text-gray-400">
            <span class="text-6xl">🔍</span>
            <p class="font-medium">Produk tidak ditemukan</p>
            <a href="/products" class="text-sm text-accent hover:underline">Lihat semua produk</a>
          </div>
        ) : (
          <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 xl:grid-cols-4">
            {products.map((p) => (
              <ProductCard
                id={p.id}
                name={p.name}
                slug={p.slug}
                primaryImage={p.primaryImage}
                lowestPrice={p.lowestPrice}
                highestPrice={p.highestPrice}
                totalStock={p.totalStock}
                tags={p.tags}
              />
            ))}
          </div>
        )}

        <Pagination page={page} totalPages={totalPages} baseUrl={baseUrl} />
      </div>
    </div>
  </div>
</BaseLayout>
