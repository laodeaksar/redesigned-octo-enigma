# ─── Shared ────────────────────────────────────────────────────────────────────
NODE_ENV=development

# All services share this secret for internal request signing
INTERNAL_SERVICE_SECRET=change-me-min-32-chars-xxxxxxxxxxxxxxx

# ─── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce

# ─── Database (MongoDB) ────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=orders

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth Service (port 3000) ──────────────────────────────────────────────────
BETTER_AUTH_SECRET=change-me-min-32-chars-xxxxxxxxxxxxxxx
BETTER_AUTH_URL=http://localhost:3000

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Payment Service (port 3003) ───────────────────────────────────────────────
# Sandbox keys start with SB-, production keys start with Mid-
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false

# ─── Email Worker ──────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@my-ecommerce.com
APP_URL=http://localhost:4321

# ─── API Gateway (port 8000) ───────────────────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:3000
PRODUCT_SERVICE_URL=http://localhost:3001
ORDER_SERVICE_URL=http://localhost:3002
PAYMENT_SERVICE_URL=http://localhost:3003
ALLOWED_ORIGINS=http://localhost:4321,http://localhost:3001

# ─── Web / Admin (public, exposed to browser) ──────────────────────────────────
PUBLIC_API_URL=http://localhost:8000
PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxxxxxx
