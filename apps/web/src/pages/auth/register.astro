---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import AuthForm from "@/components/islands/AuthForm";
import OAuthButtons from "@/components/islands/OAuthButtons";
---

<BaseLayout title="Daftar">
  <div class="flex min-h-[calc(100vh-8rem)] items-center justify-center px-4 py-12">
    <div class="w-full max-w-sm">
      <div class="mb-8 text-center">
        <h1 class="text-2xl font-bold text-gray-900">Buat Akun</h1>
        <p class="mt-1 text-sm text-gray-500">Daftar gratis dan mulai belanja</p>
      </div>
      <div class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm space-y-5">
        <AuthForm client:load mode="register" redirectTo="/" />
        <OAuthButtons client:load mode="register" redirectTo="/" />
      </div>
    </div>
  </div>
</BaseLayout>
