---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import AuthForm from "@/components/islands/AuthForm";

const redirectTo = Astro.url.searchParams.get("redirect") ?? "/";
---

<BaseLayout title="Masuk">
  <div class="flex min-h-[calc(100vh-8rem)] items-center justify-center px-4 py-12">
    <div class="w-full max-w-sm">
      <div class="mb-8 text-center">
        <h1 class="text-2xl font-bold text-gray-900">Masuk</h1>
        <p class="mt-1 text-sm text-gray-500">Masuk ke akun My Ecommerce kamu</p>
      </div>
      <div class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm">
        <AuthForm client:load mode="login" redirectTo={redirectTo} />
      </div>
    </div>
  </div>
</BaseLayout>
