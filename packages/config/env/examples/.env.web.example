# =============================================================================
# apps/web — Environment Variables (Next.js)
# Copy: cp packages/config/env/examples/.env.web.example apps/web/.env.local
#
# NEXT_PUBLIC_* vars are inlined into the client bundle at build time.
# Never put secrets in NEXT_PUBLIC_* vars.
# =============================================================================

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── API ───────────────────────────────────────────────────────────────────────
# Base URL of the api-gateway — used for server-side fetches and client calls
NEXT_PUBLIC_API_URL=http://localhost:3000
# Public URL of this app — used for absolute links, OG tags, sitemaps
NEXT_PUBLIC_APP_URL=http://localhost:3010

# ── Midtrans Snap.js ──────────────────────────────────────────────────────────
# Client key is safe to expose — it's used only in the browser Snap popup
# Get from: https://dashboard.sandbox.midtrans.com > Settings > Access Keys
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxx
# Must match MIDTRANS_IS_PRODUCTION in payment-service
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false

# ── Analytics (optional) ──────────────────────────────────────────────────────
# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Google Tag Manager
NEXT_PUBLIC_GTM_ID=