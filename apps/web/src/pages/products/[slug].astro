---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import AddToCartButton from "@/components/islands/AddToCartButton";
import Badge from "@/components/shared/Badge.astro";
import { api, type ProductDetail } from "@/lib/api";
import { formatDate } from "@/lib/utils";

const { slug } = Astro.params;

let product: ProductDetail | null = null;

try {
  const res = await api.get<{ success: true; data: ProductDetail }>(`/products/slug/${slug}`);
  product = res.data;
} catch {
  return Astro.redirect("/404");
}

if (!product || product.status !== "active") {
  return Astro.redirect("/404");
}

const primaryImage = product.images.find((i) => i.isPrimary) ?? product.images[0];
const sortedImages = [...product.images].sort((a, b) => a.sortOrder - b.sortOrder);
---

<BaseLayout
  title={product.name}
  description={product.shortDescription ?? product.description.slice(0, 160)}
>
  <div class="container mx-auto px-4 py-10">

    <!-- Breadcrumb -->
    <nav class="mb-6 flex items-center gap-2 text-sm text-gray-500">
      <a href="/" class="hover:text-gray-900">Beranda</a>
      <span>›</span>
      <a href="/products" class="hover:text-gray-900">Produk</a>
      {product.category && (
        <>
          <span>›</span>
          <a href={`/products?categoryId=${product.category.id}`} class="hover:text-gray-900">
            {product.category.name}
          </a>
        </>
      )}
      <span>›</span>
      <span class="text-gray-900 truncate max-w-[200px]">{product.name}</span>
    </nav>

    <div class="grid gap-10 lg:grid-cols-2">

      <!-- Image gallery -->
      <div class="space-y-3">
        <!-- Main image -->
        <div class="overflow-hidden rounded-2xl bg-gray-50 aspect-square">
          {primaryImage ? (
            <img
              id="main-image"
              src={primaryImage.url}
              alt={primaryImage.altText ?? product.name}
              class="h-full w-full object-cover"
            />
          ) : (
            <div class="flex h-full w-full items-center justify-center text-8xl text-gray-200">📦</div>
          )}
        </div>

        <!-- Thumbnails -->
        {sortedImages.length > 1 && (
          <div class="flex gap-2 overflow-x-auto pb-1">
            {sortedImages.map((img, i) => (
              <button
                class="thumbnail-btn h-16 w-16 shrink-0 overflow-hidden rounded-lg border-2 border-transparent transition-all hover:border-brand-500"
                data-src={img.url}
                data-alt={img.altText ?? product.name}
              >
                <img src={img.url} alt={img.altText ?? ""} class="h-full w-full object-cover" />
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- Product info + add to cart -->
      <div class="space-y-5">
        <!-- Category + name -->
        {product.category && (
          <a
            href={`/products?categoryId=${product.category.id}`}
            class="text-xs font-semibold uppercase tracking-wider text-accent hover:underline"
          >
            {product.category.name}
          </a>
        )}
        <h1 class="text-2xl font-bold text-gray-900 leading-snug sm:text-3xl">
          {product.name}
        </h1>

        {/* Short description */}
        {product.shortDescription && (
          <p class="text-gray-600 leading-relaxed">{product.shortDescription}</p>
        )}

        <!-- Tags -->
        {product.tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5">
            {product.tags.map((tag) => (
              <Badge variant="secondary">{tag}</Badge>
            ))}
          </div>
        )}

        <!-- AddToCartButton React island -->
        <div class="rounded-xl border border-gray-100 bg-white p-5 shadow-sm">
          <AddToCartButton
            client:load
            productName={product.name}
            variants={product.variants}
            primaryImage={primaryImage?.url ?? null}
          />
        </div>

        <!-- Weight + specs -->
        {product.weight && (
          <p class="text-xs text-gray-500">Berat: {product.weight}g</p>
        )}

        <!-- Shipping info -->
        <div class="flex flex-col gap-2 rounded-xl bg-gray-50 p-4 text-sm">
          {[
            { icon: "🚚", text: "Pengiriman ke seluruh Indonesia" },
            { icon: "🔒", text: "Pembayaran aman & terenkripsi" },
            { icon: "↩️", text: "Return 7 hari jika ada masalah" },
          ].map((item) => (
            <div class="flex items-center gap-2 text-gray-600">
              <span>{item.icon}</span>
              <span>{item.text}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Description -->
    <div class="mt-14">
      <h2 class="mb-4 text-xl font-bold text-gray-900">Deskripsi Produk</h2>
      <div class="prose prose-gray max-w-none text-sm leading-relaxed">
        <p>{product.description}</p>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  // Thumbnail switcher
  const mainImage = document.getElementById("main-image") as HTMLImageElement | null;
  document.querySelectorAll<HTMLButtonElement>(".thumbnail-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      if (mainImage) {
        mainImage.src = btn.dataset.src ?? "";
        mainImage.alt = btn.dataset.alt ?? "";
      }
      document.querySelectorAll(".thumbnail-btn").forEach((b) => {
        b.classList.remove("border-brand-500");
        b.classList.add("border-transparent");
      });
      btn.classList.add("border-brand-500");
      btn.classList.remove("border-transparent");
    });
  });
</script>
