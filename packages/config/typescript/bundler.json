{
    "$schema": "https://json.schemastore.org/tsconfig",
    "extends": "./base.json",
    "compilerOptions": {
        "target": "ES2022",
        "lib": [
            "ES2022"
        ],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "noEmit": false,
        "outDir": "dist",
        "types": [
            "bun-types"
        ],
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true
    },
    "include": [
        "src",
        "**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}