# =============================================================================
# apps/api-gateway — Environment Variables
# Copy: cp packages/config/env/examples/.env.api-gateway.example apps/api-gateway/.env
# =============================================================================

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=change-me-to-a-secure-random-string-minimum-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Redis (rate limiting) ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Internal Service URLs ─────────────────────────────────────────────────────
# Services talk to each other directly — never through the gateway
AUTH_SERVICE_URL=http://localhost:3001
PRODUCT_SERVICE_URL=http://localhost:3002
ORDER_SERVICE_URL=http://localhost:3003
PAYMENT_SERVICE_URL=http://localhost:3004

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3010,http://localhost:3011