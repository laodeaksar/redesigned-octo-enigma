---
import Badge from "./Badge.astro";
import { formatIDR } from "@/lib/utils";

interface Props {
  id: string;
  name: string;
  slug: string;
  primaryImage: string | null;
  lowestPrice: number;
  highestPrice: number;
  totalStock: number;
  tags?: string[];
}

const { name, slug, primaryImage, lowestPrice, highestPrice, totalStock, tags } = Astro.props;

const isOutOfStock = totalStock === 0;
const hasDiscount = lowestPrice !== highestPrice;
const priceLabel = hasDiscount
  ? `${formatIDR(lowestPrice)} – ${formatIDR(highestPrice)}`
  : formatIDR(lowestPrice);
---

<a
  href={`/products/${slug}`}
  class:list={[
    "group flex flex-col overflow-hidden rounded-xl border border-gray-100 bg-white shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md",
    isOutOfStock && "opacity-70",
  ]}
>
  <!-- Image -->
  <div class="aspect-square overflow-hidden bg-gray-50">
    {primaryImage ? (
      <img
        src={primaryImage}
        alt={name}
        class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
        loading="lazy"
      />
    ) : (
      <div class="flex h-full w-full items-center justify-center text-4xl text-gray-200">
        📦
      </div>
    )}
  </div>

  <!-- Info -->
  <div class="flex flex-1 flex-col p-4">
    <p class="line-clamp-2 text-sm font-medium text-gray-900 leading-snug">{name}</p>

    <div class="mt-2 flex items-center gap-2">
      <span class="text-base font-bold text-gray-900">{priceLabel}</span>
    </div>

    <div class="mt-2 flex flex-wrap items-center gap-1.5">
      {isOutOfStock ? (
        <Badge variant="destructive">Habis</Badge>
      ) : totalStock <= 5 ? (
        <Badge variant="warning">Sisa {totalStock}</Badge>
      ) : null}
      {tags?.slice(0, 2).map((tag) => (
        <Badge variant="secondary">{tag}</Badge>
      ))}
    </div>
  </div>
</a>
