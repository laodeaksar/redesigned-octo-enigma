# =============================================================================
# apps/admin — Environment Variables (TanStack Start / Vite)
# Copy: cp packages/config/env/examples/.env.admin.example apps/admin/.env.local
#
# VITE_* vars are inlined into the client bundle at build time.
# Never put secrets in VITE_* vars.
# =============================================================================

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── API ───────────────────────────────────────────────────────────────────────
# Base URL of the api-gateway — all admin API calls go through here
VITE_API_URL=http://localhost:3000
# Public URL of this admin app — used for absolute links
VITE_APP_URL=http://localhost:3011

# ── Auth ──────────────────────────────────────────────────────────────────────
# Base URL of auth-service — used for Better-auth client on the admin side
VITE_AUTH_URL=http://localhost:3001

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Set to "true" to use mock/seed data instead of real API calls during dev
VITE_ENABLE_MOCK_DATA=false