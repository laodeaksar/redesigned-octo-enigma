# =============================================================================
# apps/email-worker — Environment Variables
# Copy: cp packages/config/env/examples/.env.email-worker.example apps/email-worker/.env
# =============================================================================

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development
# No PORT — this is a BullMQ worker process, not an HTTP server

# ── Redis (BullMQ job queues) ─────────────────────────────────────────────────
# Shared Redis instance — email-worker reads jobs published by other services
REDIS_URL=redis://localhost:6379

# ── SMTP ──────────────────────────────────────────────────────────────────────
# Development: use Mailpit (fake SMTP + inbox UI)
#   Run: docker compose -f docker-compose.dev.yml up -d mailpit
#   Inbox UI: http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Production examples:
#   Resend SMTP:   smtp.resend.com  465  true   resend  <api-key>
#   SendGrid:      smtp.sendgrid.net  587  false  apikey  <api-key>

# ── Email Identity ────────────────────────────────────────────────────────────
EMAIL_FROM_NAME=My Ecommerce
EMAIL_FROM_ADDRESS=noreply@my-ecommerce.com
EMAIL_REPLY_TO=support@my-ecommerce.com

# ── Resend HTTP API (optional — alternative to SMTP) ─────────────────────────
RESEND_API_KEY=
