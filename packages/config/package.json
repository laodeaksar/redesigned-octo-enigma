{
  "name": "@repo/config",
  "version": "0.0.1",
  "private": true,
  "description": "Shared configuration for the monorepo: TypeScript, ESLint, and environment variables",
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.1.0"
  },
  "exports": {
    "./eslint/base":        "./eslint/index.js",
    "./eslint/next":        "./eslint/next.js",
    "./eslint/react":       "./eslint/react-internal.js",
    "./typescript/base":    "./typescript/base.json",
    "./typescript/bundler":    "./typescript/bundler.json",
    "./typescript/nextjs":  "./typescript/nextjs.json",
    "./typescript/react-lib": "./typescript/react-library.json",
    "./prettier":           "./prettier/index.js",
    "./env":         "./env/index.ts"
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo node_modules"
  },
  "dependencies": {
    "@t3-oss/env-core": "^0.13.11",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.9.0",
    "eslint-config-next": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-unicorn": "^54.0.0",
    "typescript": "^5.6.0"
  }
}

