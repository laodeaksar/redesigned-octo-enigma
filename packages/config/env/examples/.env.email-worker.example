# =============================================================================
# apps/email-worker — Environment Variables
# Copy: cp packages/config/env/examples/.env.email-worker.example apps/email-worker/.env
# =============================================================================

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development
# No PORT — this is a queue consumer, not an HTTP server

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
# Run locally: docker compose up -d rabbitmq
RABBITMQ_URL=amqp://guest:guest@localhost:5672
# Comma-separated queue names this worker subscribes to
RABBITMQ_QUEUES=email.welcome,email.order-confirmation,email.password-reset
# Max unacknowledged messages per worker instance (backpressure control)
RABBITMQ_PREFETCH=10

# ── SMTP ──────────────────────────────────────────────────────────────────────
# Development: use Mailpit (fake SMTP + inbox UI)
#   Run: docker compose up -d mailpit
#   Inbox UI: http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Production examples:
#   Resend SMTP:   smtp.resend.com  465  true   resend  <api-key>
#   SendGrid:      smtp.sendgrid.net  587  false  apikey  <api-key>
#   AWS SES:       email-smtp.<region>.amazonaws.com  587  false  <access-key>  <secret>

# ── Email Identity ────────────────────────────────────────────────────────────
EMAIL_FROM_NAME=My Ecommerce
EMAIL_FROM_ADDRESS=noreply@my-ecommerce.com
EMAIL_REPLY_TO=support@my-ecommerce.com

# ── Resend HTTP API (optional — alternative to SMTP) ─────────────────────────
# If set, Resend SDK will be used instead of nodemailer SMTP
# Get key: https://resend.com/api-keys
RESEND_API_KEY=