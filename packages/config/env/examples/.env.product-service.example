# =============================================================================
# apps/product-service — Environment Variables
# Copy: cp packages/config/env/examples/.env.product-service.example apps/product-service/.env
# =============================================================================

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3002

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Run locally: docker compose up -d postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce_products

# ── Redis (optional — product listing cache) ──────────────────────────────────
# Leave empty to skip caching (dev-friendly)
REDIS_URL=redis://localhost:6379
# Time-to-live in seconds for cached product responses (default: 5 min)
CACHE_TTL_SECONDS=300

# ── JWT ───────────────────────────────────────────────────────────────────────
# Used to verify tokens forwarded from api-gateway via x-user-* headers
JWT_SECRET=change-me-to-a-secure-random-string-minimum-32-chars

# ── S3 / Object Storage (product images) ─────────────────────────────────────
# Supports AWS S3, MinIO, Cloudflare R2, or any S3-compatible provider
# Run MinIO locally: docker compose up -d minio
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=product-images
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=ap-southeast-1
# Public CDN or bucket URL for serving images
S3_PUBLIC_URL=http://localhost:9000/product-images

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672