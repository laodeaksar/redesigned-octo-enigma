# =============================================================================
# apps/order-service — Environment Variables
# Copy: cp packages/config/env/examples/.env.order-service.example apps/order-service/.env
# =============================================================================

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3003

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Run locally: docker compose up -d mongo
# MongoDB Compass: connect with the URL below
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=orders

# ── JWT ───────────────────────────────────────────────────────────────────────
# Used to verify tokens forwarded from api-gateway via x-user-* headers
JWT_SECRET=change-me-to-a-secure-random-string-minimum-32-chars

# ── Internal Service URLs ─────────────────────────────────────────────────────
# order-service calls product-service to validate & deduct stock
PRODUCT_SERVICE_URL=http://localhost:3002
# order-service calls payment-service to create Midtrans transactions
PAYMENT_SERVICE_URL=http://localhost:3004

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ── Order Settings ────────────────────────────────────────────────────────────
# Minutes before an unpaid order is automatically cancelled and stock restored
ORDER_EXPIRY_MINUTES=60