{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Node / Bun Server",
  "extends": "./base.json",
  "compilerOptions": {
    /* Bun supports modern targets natively */
    "target":           "ES2022",
    "lib":              ["ES2022"],
    "module":           "ESNext",
    "moduleResolution": "Bundler",

    /* Bun handles transpilation — only emit types */
    "noEmit":           true,

    /* Elysia/Hono use decorator patterns */
    "experimentalDecorators":   true,
    "emitDecoratorMetadata":    true,

    /* Paths — extend per-service */
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", "**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
