{
  "extends": "@repo/config/typescript/base",
  "compilerOptions": {
    "lib":["dom"],
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@repo/common/*": ["./*"]
    }
  },
  "include": [
    "types/**/*.ts",
    "schemas/**/*.ts",
    "errors/**/*.ts",
    "events/**/*.ts",
    "index.ts"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.ts"
  ]
}
