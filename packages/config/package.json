{
  "name": "@repo/config",
  "version": "0.0.0",
  "private": true,
  "description": "Shared configuration for the monorepo: TypeScript, ESLint, and environment variables",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.1.0"
  },
  "workspaces": [
    "tsconfig",
    "eslint-config",
    "env",
    "prettier"
  ],
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo node_modules"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
