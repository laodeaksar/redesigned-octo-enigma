---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import CheckoutForm from "@/components/islands/CheckoutForm";
import { requireAuth, getTokenFromCookies } from "@/lib/auth";
import { api } from "@/lib/api";

// Requires auth — redirects to login if not logged in
const user = await requireAuth(Astro.cookies, `/auth/login?redirect=/checkout`);
const token = getTokenFromCookies(Astro.cookies)!;

// Fetch saved addresses
let addresses: Array<{
  id: string; label: string; recipientName: string;
  phone: string; street: string; city: string;
  province: string; postalCode: string;
}> = [];

try {
  const res = await api.get<{ success: true; data: typeof addresses }>(
    "/users/me/addresses",
    { token }
  );
  addresses = res.data;
} catch {
  // no addresses — show empty state inside form
}

// Load Midtrans Snap.js
const midtransScriptUrl = import.meta.env.PUBLIC_MIDTRANS_IS_PRODUCTION === "true"
  ? "https://app.midtrans.com/snap/snap.js"
  : "https://app.sandbox.midtrans.com/snap/snap.js";
---

<BaseLayout title="Checkout">
  <!-- Midtrans Snap.js (loaded before island hydrates) -->
  <script
    is:inline
    src={midtransScriptUrl}
    data-client-key={import.meta.env.PUBLIC_MIDTRANS_CLIENT_KEY}
  ></script>

  <div class="container mx-auto px-4 py-10">
    <h1 class="mb-8 text-2xl font-bold text-gray-900">Checkout</h1>
    <CheckoutForm client:load addresses={addresses} token={token} />
  </div>
</BaseLayout>
