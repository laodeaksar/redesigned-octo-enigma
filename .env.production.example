# =============================================================================
# Production environment variables
# Copy: cp .env.production.example .env
# NEVER commit the actual .env file — it contains secrets
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=ecommerce

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_USER=mongo
MONGO_PASSWORD=change-me-strong-password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-strong-password

# ── MinIO / S3 ────────────────────────────────────────────────────────────────
MINIO_ACCESS_KEY=change-me-access-key
MINIO_SECRET_KEY=change-me-secret-key
S3_BUCKET=product-images
S3_REGION=ap-southeast-1
S3_PUBLIC_URL=https://cdn.my-ecommerce.com

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-minimum-32-char-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BETTER_AUTH_SECRET=change-me-minimum-32-char-random-secret

# ── Midtrans ──────────────────────────────────────────────────────────────────
MIDTRANS_SERVER_KEY=Mid-server-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=Mid-client-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=true
PAYMENT_WEBHOOK_URL=https://api.my-ecommerce.com/payments/webhook

# ── RajaOngkir ────────────────────────────────────────────────────────────────
RAJAONGKIR_API_KEY=your-rajaongkir-api-key
RAJAONGKIR_ORIGIN=501

# ── Email (SMTP or Resend) ────────────────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM_NAME=My Ecommerce
EMAIL_FROM_ADDRESS=noreply@my-ecommerce.com
EMAIL_REPLY_TO=support@my-ecommerce.com
# Or use Resend HTTP API instead of SMTP:
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── CORS & public URLs ────────────────────────────────────────────────────────
CORS_ORIGINS=https://my-ecommerce.com,https://admin.my-ecommerce.com
PUBLIC_API_URL=https://api.my-ecommerce.com

# ── Port mapping (change if ports conflict on host) ───────────────────────────
API_PORT=3000
WEB_PORT=3010
ADMIN_PORT=3011
