# =============================================================================
# apps/auth-service — Environment Variables
# Copy: cp packages/config/env/examples/.env.auth-service.example apps/auth-service/.env
# =============================================================================

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Run locally: docker compose up -d postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce_auth

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must match the secret used in api-gateway
# Generate: openssl rand -base64 32
JWT_SECRET=change-me-to-a-secure-random-string-minimum-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Better-auth ───────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-secure-random-string-minimum-32-chars
# Base URL of this service — used for OAuth redirect URIs
BETTER_AUTH_URL=http://localhost:3001

# ── OAuth Providers (optional) ────────────────────────────────────────────────
# Google: https://console.cloud.google.com > APIs & Services > Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
# Run locally: docker compose up -d rabbitmq
# Management UI: http://localhost:15672 (guest/guest)
RABBITMQ_URL=amqp://guest:guest@localhost:5672