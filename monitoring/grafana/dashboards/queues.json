{
  "uid": "ecommerce-queues",
  "title": "My Ecommerce — BullMQ Queue Health",
  "description": "Queue depths, job throughput, failure rates, and worker status for all BullMQ queues",
  "tags": ["ecommerce", "bullmq", "queues"],
  "timezone": "Asia/Jakarta",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },

  "templating": {
    "list": [
      {
        "name":       "queue",
        "type":       "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query":      "label_values(bullmq_queue_depth, queue)",
        "multi":      true,
        "includeAll": true,
        "current":    { "text": "All", "value": "$__all" },
        "refresh":    2
      }
    ]
  },

  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active Workers",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "green",  "value": 3 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "sum(bullmq_workers_active{queue=~\"$queue\"})",
        "legendFormat": "Workers"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Total Waiting Jobs",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": 0 },
              { "color": "yellow", "value": 50 },
              { "color": "red",    "value": 200 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "sum(bullmq_queue_depth{state=\"waiting\", queue=~\"$queue\"})",
        "legendFormat": "Waiting"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Total Failed Jobs",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": 0 },
              { "color": "yellow", "value": 10 },
              { "color": "red",    "value": 50 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "sum(bullmq_queue_depth{state=\"failed\", queue=~\"$queue\"})",
        "legendFormat": "Failed"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Job Throughput (last 5m)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 1 } },
      "targets": [{
        "expr": "sum(rate(bullmq_jobs_completed_total{queue=~\"$queue\"}[5m])) * 60",
        "legendFormat": "Jobs/min"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "Queue Depth by State",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "short" }
      },
      "targets": [
        {
          "expr":         "bullmq_queue_depth{state=\"waiting\", queue=~\"$queue\"}",
          "legendFormat": "{{ queue }} — waiting"
        },
        {
          "expr":         "bullmq_queue_depth{state=\"active\", queue=~\"$queue\"}",
          "legendFormat": "{{ queue }} — active"
        },
        {
          "expr":         "bullmq_queue_depth{state=\"failed\", queue=~\"$queue\"}",
          "legendFormat": "{{ queue }} — failed"
        },
        {
          "expr":         "bullmq_queue_depth{state=\"delayed\", queue=~\"$queue\"}",
          "legendFormat": "{{ queue }} — delayed"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "Job Completion Rate (jobs/min)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } },
      "targets": [{
        "expr":         "sum by (queue) (rate(bullmq_jobs_completed_total{queue=~\"$queue\"}[5m]) * 60)",
        "legendFormat": "{{ queue }}"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Job Failure Rate (jobs/min)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red",   "value": 1 }
            ]
          }
        }
      },
      "targets": [{
        "expr":         "sum by (queue) (rate(bullmq_jobs_failed_total{queue=~\"$queue\"}[5m]) * 60)",
        "legendFormat": "{{ queue }}"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },

    {
      "id": 8,
      "type": "heatmap",
      "title": "Job Processing Time Distribution",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "options": {
        "calculate": false,
        "color": { "mode": "scheme", "scheme": "Blues", "fill": "dark-green", "exponent": 0.5 },
        "tooltip": { "show": true, "yHistogram": false }
      },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [{
        "expr":         "sum by (le) (rate(bullmq_job_duration_seconds_bucket{queue=~\"$queue\"}[5m]))",
        "legendFormat": "{{ le }}",
        "format":       "heatmap"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    }
  ]
}

