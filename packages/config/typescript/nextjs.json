{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Next.js",
  "extends": "./base.json",
  "compilerOptions": {
    /* Next.js requires DOM lib */
    "lib":                ["ES2022", "DOM", "DOM.Iterable"],

    /* Next.js uses its own bundler */
    "moduleResolution":   "Bundler",
    "module":             "ESNext",

    /* JSX handled by Next.js SWC */
    "jsx":                "preserve",
    "incremental":        true,

    /* Disable verbatimModuleSyntax — incompatible with some Next internals */
    "verbatimModuleSyntax": false,
    "allowImportingTsExtensions": false,

    /* Path aliases — extend per-app as needed */
    "paths": {
      "@/*": ["./*"]
    },

    /* Required by Next.js */
    "allowJs":            true,
    "noEmit":             true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".next"
  ]
}
